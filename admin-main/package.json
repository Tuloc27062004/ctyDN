{
  "name": "b2b-sales-admin",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "npm run prisma:seed && next start",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && next build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:api": "vitest run tests/api",
    "test:integration": "vitest run tests/integration",
    "test:ci": "npm run test:api && npm run test:integration:db",
    "docker:test:up": "docker compose -f docker-compose.test.yml up -d",
    "docker:test:down": "docker compose -f docker-compose.test.yml down -v",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --config prisma/prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config prisma/prisma.config.ts",
    "prisma:test:migrate": "dotenv -e .env.test -- prisma migrate deploy --config prisma/prisma.config.ts",
    "prisma:seed": "tsx prisma/seed.ts",
    "test:integration:db": "npm run docker:test:up && npm run prisma:test:migrate && vitest run tests/integration",
    "test:integration:db:down": "npm run docker:test:down"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@hookform/resolvers": "^5.2.2",
    "@mdxeditor/editor": "^3.52.4",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.12",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tanstack/react-table": "^8.21.2",
    "@vercel/blob": "^0.27.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.542.0",
    "next": "^16.1.0",
    "next-auth": "5.0.0-beta.30",
    "next-swagger-doc": "^0.4.1",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.62.0",
    "recharts": "^2.15.4",
    "resend": "^6.9.4",
    "swagger-ui-react": "^5.32.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.184.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/swagger-ui-react": "^5.18.0",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.1.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.49",
    "prisma": "^7.4.2",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.20.0",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
